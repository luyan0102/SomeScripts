# 复制为项目根目录 .env 后，脚本会自动加载
export COINGLASS_API_KEY=your_coinglass_api_key
export COINGLASS_BASE_URL=https://open-api-v4.coinglass.com
export COINGLASS_COIN_SYMBOL=BTC
export COINGLASS_EXCHANGE=Binance

export ENABLE_ALERTS=1

export DINGTALK_WEBHOOK1=https://oapi.dingtalk.com/robot/send?access_token=your_access_token_1
export DINGTALK_SECRET1=SECxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx1
export DINGTALK_WEBHOOK2=https://oapi.dingtalk.com/robot/send?access_token=your_access_token_2
export DINGTALK_SECRET2=SECxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx2
export DINGTALK_WEBHOOK3=https://oapi.dingtalk.com/robot/send?access_token=your_access_token_3
export DINGTALK_SECRET3=SECxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx3
export SEND_OBSERVE_ALERTS=0

export LOOP_INTERVAL=30
export ALERT_COOLDOWN_SECONDS=300
export REQUEST_TIMEOUT=10
export MARKET_CACHE_SECONDS=60
export ETF_CACHE_SECONDS=3600
export MACRO_CACHE_SECONDS=21600
export RUN_ONCE=0

export ETF_FLOW_MILLION=
export ETF_STRONG_INFLOW_MILLION=100
export ETF_STRONG_OUTFLOW_MILLION=-100
export ETF_FLOW_PATH=/api/etf/bitcoin/flow-history

export FRED_API_KEY=
export FRED_BASE_URL=https://api.stlouisfed.org
export FRED_CPI_SERIES_ID=CPIAUCSL
export FRED_CORE_CPI_SERIES_ID=CPILFESL
export MACRO_ACTUAL=
export MACRO_FORECAST=
export MACRO_SURPRISE_THRESHOLD=0.2
export MACRO_COOLING_THRESHOLD=0.1
export MACRO_HEATING_THRESHOLD=0.1

export ENABLE_TWITTER_SENTIMENT=0
export TWITTER_QUERY='Bitcoin OR BTC Fed CPI lang:en'
export TWITTER_SAMPLE_SIZE=20

export FUNDING_BEARISH_THRESHOLD=0.0005
export FUNDING_BULLISH_THRESHOLD=0.0005
export MIN_LIQUIDATION_USD_1H=500000
export LIQUIDATION_IMBALANCE_RATIO=2.0
